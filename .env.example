# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# When set, Vite's dev server will proxy requests to /ussd-proxy/* → this URL.
# This bypasses CORS restrictions during development.
# Example: if your USSD backend lives at http://localhost:8000,
# set VITE_PROXY_TARGET=http://localhost:8000 and use the endpoint URL
# http://localhost:5173/ussd-proxy/ussd in the simulator Live mode panel.
VITE_PROXY_TARGET=http://localhost:8000
